# Copy to backend.tf after creating the remote state bucket and lock table.
# This file intentionally contains no credentials.
terraform {
  backend "s3" {
    bucket         = "replace-with-terraform-state-bucket"
    key            = "dynamo-music-streaming/dev/terraform.tfstate"
    region         = "us-east-1"
    dynamodb_table = "replace-with-terraform-lock-table"
    encrypt        = true
  }
}
